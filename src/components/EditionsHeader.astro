---
// EditionsHeader.astro: This component defines the header for the "Editions" pages.
// It is simpler than MainHeader.astro as it primarily provides a way to go back home.
---

<header class="site-head is-visible">
  <div class="site-head__container">
    <div class="sb-logo">
      <a href="/">
        <!-- The logo image. Displayed at 48x48 pixels. -->
        <img 
          src="/images/logo.png" 
          alt="The Chronicle Logo" 
          class="logo-img"
          width="48"
          height="48"
        />
        <!-- Hidden text for screen readers (accessibility) -->
        <span class="u-sr-only">The Chronicle</span>
      </a>
    </div>

    <nav class="sb-menu">
      <ul class="sb__list">
        <li class="sb__item">
          <a href="/#stats" class="js-menu-link">
            <span class="sb__text">Departments</span>
          </a>
        </li>
        <li class="sb__item">
          <a href="#contact" class="js-menu-link">
            <span class="sb__text">Contact</span>
          </a>
        </li>
      </ul>
    </nav>


    <ul class="sb-socials">
      <li class="sb__item">
        <a href="https://www.instagram.com/thechronicleattslas?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" target="_blank" rel="noopener">
          <span class="sb__icon" style="--path: path('M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.917 3.917 0 0 0-1.417.923A3.927 3.927 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.21.547.502.979.923 1.417.438.42.859.711 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.916 3.916 0 0 0 1.416-.923c.421-.438.713-.859.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.926 3.926 0 0 0-.923-1.417A3.911 3.911 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0h.003zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599.28.28.453.546.598.92.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.47 2.47 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.478 2.478 0 0 1-.92-.598 2.48 2.48 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233 0-2.136.008-2.388.046-3.231.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92.28-.28.546-.453.92-.598.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045v.002zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92zm-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217zm0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334z');"></span>
          <span class="u-sr-only">Follow on Instagram</span>
        </a>
      </li>
    </ul>

    <button class="sb-contrast js-contrast" type="button">
      <span class="sb__icon" style="--path: path('M10.0996 20C8.71628 20 7.41628 19.7373 6.19961 19.212C4.98294 18.6867 3.92461 17.9743 3.02461 17.075C2.12461 16.1757 1.41228 15.1173 0.887611 13.9C0.362944 12.6827 0.100277 11.3827 0.0996106 10C0.098944 8.61733 0.361611 7.31733 0.887611 6.1C1.41361 4.88267 2.12594 3.82433 3.02461 2.925C3.92328 2.02567 4.98161 1.31333 6.19961 0.788C7.41761 0.262667 8.71761 0 10.0996 0C11.4816 0 12.7816 0.262667 13.9996 0.788C15.2176 1.31333 16.2759 2.02567 17.1746 2.925C18.0733 3.82433 18.7859 4.88267 19.3126 6.1C19.8393 7.31733 20.1016 8.61733 20.0996 10C20.0976 11.3827 19.8349 12.6827 19.3116 13.9C18.7883 15.1173 18.0759 16.1757 17.1746 17.075C16.2733 17.9743 15.2149 18.687 13.9996 19.213C12.7843 19.739 11.4843 20.0013 10.0996 20ZM11.0996 17.925C13.0829 17.675 14.7456 16.804 16.0876 15.312C17.4296 13.82 18.1003 12.0493 18.0996 10C18.0989 7.95067 17.4279 6.18 16.0866 4.688C14.7453 3.196 13.0829 2.325 11.0996 2.075V17.925Z');"></span>
      <span class="u-sr-only">Change contrast</span>
    </button>
  </div>
</header>

<div class="js-contrast-mask contrast-mask"></div>

<script>
  // Import the event emitter to communicate between components
  import Emitter from '../utils/Emitter'
  // Import GSAP for high-quality animations
  import { gsap } from 'gsap'

  /**
   * EditionsHeader class manages the header functions for editions pages:
   * - Toggling between light and dark contrast modes
   * - Smooth scrolling to sections
   * - Intro animation
   */
  class EditionsHeader {
    el: HTMLElement
    contrastButton: HTMLElement
    contrastMask: HTMLElement
    links: NodeListOf<HTMLElement>

    /**
     * Constructor: Initializes the editions header logic
     */
    constructor() {
      this.el = document.querySelector('.site-head')
      this.contrastButton = document.querySelector('.js-contrast')
      this.contrastMask = document.querySelector('.js-contrast-mask')
      this.links = this.el.querySelectorAll('.js-menu-link')

      this.init()
    }

    /**
     * Init
     */
    init() {
      this.bindEvents()
      this.intro()
    }

    /**
     * Bind events
     */
    bindEvents() {
      if (this.contrastButton) {
        this.contrastButton.addEventListener('click', this.toggleContrast.bind(this))
      }

      this.links.forEach((link) => {
        link.addEventListener('click', this.moveToSection.bind(this))
      })
    }

    /**
     * Intro animation
     */
    intro() {
      const logo = this.el.querySelector('.logo-img')
      const menuItems = this.el.querySelectorAll('.sb__item')
      const contrast = this.contrastButton

      const items = [logo, ...menuItems, contrast]

      const tl = gsap.timeline()

      tl.set(this.el, { opacity: 1 })
      
      tl.from(this.el, {
        y: '-100%',
        duration: 1.5,
        ease: 'expo.inOut',
      }, 0.5)

      tl.from(items, {
        y: '-100%',
        duration: 1.2,
        ease: 'expo.out',
        stagger: 0.1,
      }, 1.2)
    }

    /**
     * Move to section
     */
    moveToSection(e) {
      const id = e.currentTarget.getAttribute('href')

      if (id === '#contact') {
        e.preventDefault()
        Emitter.emit('openContact')
        return
      }

      // If it's an external link or a complex path like /#stats, don't prevent default
      if (id.startsWith('/')) {
        return
      }
      
      e.preventDefault()
      // @ts-ignore - window.lenis is initialized in index.astro
      if (window.lenis) {
        window.lenis.scrollTo(id, {
          duration: 1.5,
          easing: (t) => t < 0.5 ? 16 * t * t * t * t * t : 1 + 16 * --t * t * t * t * t,
        })
      }
    }

    /**
     * Toggle contrast: Switches light/dark theme with a sliding mask animation
     */
    toggleContrast() {
      let fromX = '0'
      let toX = '-100%'

      // Check current state in the browser's global HTML document tag
      if (document.documentElement.classList.contains('theme-contrasted')) {
        fromX = '-100%'
        toX = '0'
      }

      // Animate the mask to sweep across the screen
      gsap.fromTo(
        this.contrastMask,
        { x: fromX },
        {
          x: toX,
          duration: 1,
          ease: 'expo.inOut',
          onComplete: () => {
            // Reset position after animation finishes
            this.contrastMask.style.transform = ''
            
            // Apply the actual CSS class to swap colors site-wide
            if (toX === '0') {
              document.documentElement.classList.remove('theme-contrasted')
            } else {
              document.documentElement.classList.add('theme-contrasted')
            }

            Emitter.emit(
              'contrastchange',
              document.documentElement.classList.contains('theme-contrasted')
                ? 'contrasted'
                : 'default'
            )
          },
        }
      )

      if (toX !== '0') {
        document.documentElement.classList.add('theme-contrasted')
      }
    }
  }

  // Create a new instance to activate the header logic
  new EditionsHeader()
</script>

<style lang="scss">
  .site-head {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 100;
    width: 100%;
    border-bottom: 1px solid color(primary);
    background: rgba(color(secondary), 0.85);
    backdrop-filter: blur(15px);
    opacity: 0; // Starts hidden for intro animation

    &__container {
      @include flex(row, stretch, space-between);
      width: 100%;
      height: 6rem;

      @include mq(phone) {
        height: 4rem;
      }
    }

    .sb-logo {
      padding: 1.5rem;
      width: 12rem; // Matches right side icons width (6rem + 6rem)
      height: 6rem;
      border-left: 1px solid color(primary);
      border-right: 1px solid color(primary);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;

      @include mq(phone) {
        width: 4rem;
        height: 4rem;
        border-left: 0;
      }

      a {
        display: block;
        transition: transform 0.6s ease(out-expo);

        &:hover {
          transform: scale(1.1) rotate(5deg);
        }
      }

      .logo-img {
        width: 3rem;
        height: 3rem;
        object-fit: contain;

        @include mq(phone) {
          width: 2rem;
          height: 2rem;
        }
      }
    }

    .sb-menu {
      flex-grow: 1;
      display: flex;
      align-items: center;
      justify-content: center;

      .sb__list {
        display: flex;
        list-style: none;
        padding: 0;
      }

      .sb__item {
        overflow: hidden;
      }

      a {
        position: relative;
        display: block;
        padding: 2rem 2.5rem;
        text-decoration: none;
        color: color(primary);
        font: 400 14px / 1 font-family(fraktion);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        
        @include mq(phone) {
          padding: 1rem;
          font-size: 12px;
        }

        .sb__text {
          position: relative;
          display: inline-block;

          &:before {
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 100%;
            height: 1px;
            background: currentcolor;
            scale: 0 1;
            transform-origin: 100% 50%;
            transition: scale 0.4s ease(out-expo);
            content: '';
          }
        }

        &:hover {
          .sb__text:before {
            scale: 1 1;
            transform-origin: 0 50%;
          }
        }
      }
    }

    .sb-socials {
      margin: 0;
      padding: 0;
      display: flex;
      list-style: none;
      border-left: 1px solid color(primary);

      @include mq(phone) {
        display: none;
      }

      .sb__item {
        border-right: 1px solid color(primary);
        overflow: hidden;
      }

      a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 6rem;
        height: 6rem;
        color: color(primary);
        transition: background 0.4s ease, color 0.4s ease;

        &:hover {
          background: color(primary);
          color: color(secondary);
        }
      }

      .sb__icon {
        display: block;
        width: 20px;
        height: 20px;
        background: currentColor;
        clip-path: var(--path);
      }
    }

    .sb-contrast {
      width: 6rem;
      height: 6rem;
      border: 0;
      border-right: 1px solid color(primary);
      background: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      color: color(primary);
      transition: background 0.4s ease, color 0.4s ease;
      overflow: hidden;

      @include mq(phone) {
        width: 4rem;
        height: 4rem;
        border-left: 1px solid color(primary);
        border-right: 0;
      }

      &:hover {
        background: color(primary);
        color: color(secondary);
      }

      .sb__icon {
        width: 20px;
        height: 20px;
        background: currentColor;
        clip-path: var(--path);
      }
    }
  }

  .contrast-mask {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 9999;
    width: 100%;
    height: 100%;
    background: color(primary);
    pointer-events: none;
    transform: translateX(100%);
    will-change: transform;
  }
</style>
