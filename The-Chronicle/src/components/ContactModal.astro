---
// ContactModal.astro
---
<div class="contact-modal js-contact-modal">
  <div class="contact-modal__overlay js-contact-modal-overlay"></div>
  <div class="contact-modal__content js-contact-modal-content">
    <button class="contact-modal__close js-contact-modal-close" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <div class="contact-modal__body">
      <h3 class="contact-modal__title">Get in Touch</h3>
      <p class="contact-modal__message">We'd love to hear from you!</p>
      <a href="mailto:thechronicle@thapar.edu" class="contact-modal__email">thechronicle@thapar.edu</a>
      
      <div class="contact-modal__actions">
        <button class="contact-modal__back js-contact-modal-close">Back to Site</button>
      </div>
    </div>
  </div>
</div>

<style lang="scss">
  .contact-modal {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 2000;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    visibility: hidden;

    &.is-active {
      pointer-events: all;
      visibility: visible;
    }

    &__overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.85);
      backdrop-filter: blur(8px);
      opacity: 0;
    }

    &__content {
      position: relative;
      width: 90%;
      max-width: 500px;
      padding: 4rem 2rem;
      background: color(primary);
      color: color(secondary);
      border: 1px solid color(secondary);
      text-align: center;
      transform: translateY(30px);
      opacity: 0;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }

    &__close {
      position: absolute;
      top: 1.5rem;
      right: 1.5rem;
      background: none;
      border: none;
      color: inherit;
      cursor: pointer;
      padding: 0.5rem;
      transition: transform 0.4s ease(in-out-expo);

      &:hover {
        transform: rotate(90deg) scale(1.1);
      }
    }

    &__title {
      font: 700 2.5rem / 1.1 font-family(bigger);
      text-transform: uppercase;
      margin-bottom: 1rem;
      letter-spacing: 0.05em;

      @include mq(phone) {
        font-size: 2rem;
      }
    }

    &__message {
      font: 400 1.25rem / 1.5 font-family(editorial);
      margin-bottom: 2.5rem;
      opacity: 0.8;
    }

    &__email {
      display: inline-block;
      font: 400 1.4rem / 1 font-family(fraktion);
      color: color(secondary);
      text-decoration: none;
      border-bottom: 1px solid color(secondary);
      padding-bottom: 0.4rem;
      transition: all 0.3s ease;

      &:hover {
        opacity: 0.6;
        transform: translateY(-2px);
      }
    }

    &__actions {
      margin-top: 3rem;
    }

    &__back {
      background: none;
      border: 1px solid color(secondary);
      color: color(secondary);
      padding: 0.8rem 2rem;
      font: 400 12px / 1 font-family(fraktion);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      cursor: pointer;
      transition: all 0.3s ease;

      &:hover {
        background: color(secondary);
        color: color(primary);
      }
    }
  }
</style>

<script>
  import Emitter from '../utils/Emitter'
  import { gsap } from 'gsap'

  class ContactModal {
    el: HTMLElement | null
    overlay: HTMLElement | null
    content: HTMLElement | null
    closeBtn: HTMLElement | null

    constructor() {
      this.el = document.querySelector('.js-contact-modal')
      if (!this.el) return

      this.overlay = this.el.querySelector('.js-contact-modal-overlay')
      this.content = this.el.querySelector('.js-contact-modal-content')
      this.closeBtns = this.el.querySelectorAll('.js-contact-modal-close')

      this.init()
    }

    init() {
      this.bindEvents()
    }

    bindEvents() {
      Emitter.on('openContact', this.open, this)
      this.closeBtns?.forEach(btn => btn.addEventListener('click', this.close.bind(this)))
      this.overlay?.addEventListener('click', this.close.bind(this))
    }

    open() {
      if (!this.el || !this.overlay || !this.content) return

      this.el.classList.add('is-active')
      document.body.style.overflow = 'hidden' // Block scroll
      
      const tl = gsap.timeline()
      tl.to(this.overlay, { opacity: 1, duration: 0.4, ease: 'power2.out' })
      tl.to(this.content, { 
        opacity: 1, 
        y: 0, 
        duration: 0.6, 
        ease: 'expo.out' 
      }, '-=0.2')
    }

    close() {
      if (!this.el || !this.overlay || !this.content) return

      const tl = gsap.timeline({
        onComplete: () => {
          this.el?.classList.remove('is-active')
          document.body.style.overflow = '' // Restore scroll
        }
      })
      tl.to(this.content, { opacity: 0, y: 30, duration: 0.4, ease: 'expo.in' })
      tl.to(this.overlay, { opacity: 0, duration: 0.4, ease: 'power2.in' }, '-=0.2')
    }
  }

  // Ensure singleton and immediate init
  if (!window.contactModalInstance) {
    window.contactModalInstance = new ContactModal()
  }
</script>
